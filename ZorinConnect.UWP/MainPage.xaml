<Page
    x:Class="ZorinConnect.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Zorin Connect" FontSize="28" HorizontalAlignment="Center" />
            <TextBlock x:Name="StatusText" Text="Scaffold build — protocol core lands in T3+"
                       FontSize="14" Opacity="0.7" HorizontalAlignment="Center" Margin="0,8,0,0" />
        </StackPanel>
    </Grid>
</Page>
