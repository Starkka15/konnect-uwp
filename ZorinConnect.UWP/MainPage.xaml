<Page
    x:Class="ZorinConnect.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="200" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBox x:Name="NameBox" FontSize="20" MinWidth="200" />
            <Button Content="Rename" Click="OnRenameClick" Margin="8,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Grid.Row="1" x:Name="OwnIdText" FontSize="11" Opacity="0.6" TextWrapping="Wrap" Margin="0,2,0,8" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="RefreshButton" Content="Refresh" Click="OnRefreshClick" VerticalAlignment="Center" />
            <TextBlock Text="Mouse:" VerticalAlignment="Center" Margin="16,0,4,0" Opacity="0.7" />
            <Slider x:Name="SensSlider" Minimum="0.2" Maximum="3.0" StepFrequency="0.1"
                    Width="140" VerticalAlignment="Center" ValueChanged="OnSensChanged" />
            <TextBlock x:Name="SensValue" VerticalAlignment="Center" Margin="6,0,0,0" Opacity="0.7" />
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,8">
            <Button x:Name="MainMountButton" Content="Give permission for Main"
                    Click="OnGrantMain" HorizontalAlignment="Stretch" Margin="0,0,0,4" />
            <Button x:Name="SdMountButton" Content="Give permission for SD Card"
                    Click="OnGrantSdCard" HorizontalAlignment="Stretch" Margin="0,0,0,4" />
            <StackPanel Orientation="Horizontal">
                <Button x:Name="ShareFolderButton" Content="Save folder…" Click="OnPickShareFolder" />
                <Button x:Name="ClearMountButton" Content="Clear mounts" Click="OnClearMountFolders" Margin="8,0,0,0" />
            </StackPanel>
            <TextBlock x:Name="StorageStatus" FontSize="11" Opacity="0.7" TextWrapping="Wrap" Margin="0,4,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="4">
            <StackPanel x:Name="DevicePanel" />
        </ScrollViewer>

        <ScrollViewer Grid.Row="5" x:Name="LogScroll" Margin="0,8,0,0"
                      Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
            <TextBlock x:Name="LogText" FontSize="10" FontFamily="Consolas" TextWrapping="Wrap" Padding="6" />
        </ScrollViewer>

        <Grid x:Name="RingOverlay" Grid.RowSpan="6" Background="#DD15A6F0" Visibility="Collapsed"
              Tapped="OnDismissRing">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE1D6;" FontFamily="Segoe MDL2 Assets" FontSize="72"
                           Foreground="White" HorizontalAlignment="Center" />
                <TextBlock Text="Found it!" FontSize="32" Foreground="White" HorizontalAlignment="Center" Margin="0,16,0,0" />
                <TextBlock Text="tap anywhere to stop" FontSize="16" Foreground="White" Opacity="0.8"
                           HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
